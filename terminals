PROJECT ROOT
~/projects/aml-tx-detection

TERMINAL 1 — INFRA (Docker)

cd ~/projects/aml-tx-detection
sudo docker start neo4j
sudo docker start redpanda

TERMINAL 2 — GRAPH BUILDER (MOST IMPORTANT)

cd ~/projects/aml-tx-detection/services/graph-builder
source ../../venv/bin/activate
export PYTHONPATH=$(pwd)
python -m app.main

(Keep this open — shows Kafka messages)

TERMINAL 3 — INGESTION SERVICE

cd ~/projects/aml-tx-detection/services/ingestion-service
source ../../venv/bin/activate
uvicorn app.main:app --reload --port 8000

Check: http://127.0.0.1:8000/docs

TERMINAL 4 — ALERT SERVICE (optional)

cd ~/projects/aml-tx-detection/services/alert-service
source ../../venv/bin/activate
uvicorn app.main:app --reload --port 8001

TERMINAL 5 — FEATURE SERVICE (optional)

cd ~/projects/aml-tx-detection/services/feature-service
source ../../venv/bin/activate
python -m app.main

TERMINAL 6 — LOADER (run only when needed)

cd ~/projects/aml-tx-detection
python scripts/load_aml_dataset.py

